# Local dev environment for hunt-and-peck.
# Copy this file to `.env` and fill in your values. `.env` is gitignored —
# keep personal/local values (IPs, usernames, paths) out of committed files.
#
# CLAUDE.md and the skills under .claude/skills/ reference these vars.
# Source `.env` before running a skill's commands, e.g.:
#   set -a; . ./.env; set +a

# Absolute path to this repo on the dev (Linux) box.
HAP_REPO=/path/to/hunt-and-peck

# GitHub fork (owner/repo) where CI runs and where you push.
# (Upstream is zsims/hunt-and-peck.)
HAP_FORK_REPO=your-name/hunt-and-peck

# Windows test box — the app is Windows-only WPF, so runtime builds are
# tested there. SSH reaches the box's WSL, which mounts C: at /mnt/c.
HAP_WIN_HOST=10.0.0.0
HAP_WIN_USER=your-ssh-user

# WSL-mount paths on the Windows box (reachable over SSH):
HAP_WIN_TEST_DIR=/mnt/c/path/to/test/dir                      # build drops go here
HAP_WIN_TEMP=/mnt/c/Users/YourWinUser/AppData/Local/Temp      # == %TEMP% (hap-timing.log lives here)
