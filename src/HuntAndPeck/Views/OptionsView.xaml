<Window x:Class="HuntAndPeck.Views.OptionsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hunt-and-Peck Options" Height="560" Width="380"
        WindowStartupLocation="CenterScreen">
    <TabControl TabStripPlacement="Left">
        <TabItem Header="Overlay">
            <TabItem.Content>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="Trigger mode" FontWeight="Bold" />
                        <ComboBox SelectedValue="{Binding OverlayTriggerMode}" SelectedValuePath="Content" Margin="0,2,0,4">
                            <ComboBoxItem>OneClick</ComboBoxItem>
                            <ComboBoxItem>Continuous</ComboBoxItem>
                        </ComboBox>
                        <TextBlock Text="OneClick closes after one click; Continuous stays up for repeated clicks until Esc (Grid only). Press the hotkey again to toggle." FontStyle="Italic" Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap" />

                        <TextBlock Text="Hint source" FontWeight="Bold" />
                        <ComboBox SelectedValue="{Binding HintSource}" SelectedValuePath="Content" Margin="0,2,0,10">
                            <ComboBoxItem>Grid</ComboBoxItem>
                            <ComboBoxItem>Automation</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="Overlay bounds" FontWeight="Bold" />
                        <ComboBox SelectedValue="{Binding HintBoundsSource}" SelectedValuePath="Content" Margin="0,2,0,10">
                            <ComboBoxItem>Screen</ComboBoxItem>
                            <ComboBoxItem>Window</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="Hint characters" FontWeight="Bold" />
                        <TextBox Text="{Binding HintCharacters}" Margin="0,2,0,10" />

                        <TextBlock Text="Pill opacity (0-100; lower = more see-through, text stays crisp)" FontWeight="Bold" />
                        <TextBox Text="{Binding HintPillOpacity}" Margin="0,2,0,10" />

                        <TextBlock Text="Dimmed opacity (0-100; backtick dim level for reading behind)" FontWeight="Bold" />
                        <TextBox Text="{Binding HintDimOpacity}" Margin="0,2,0,10" />

                        <TextBlock Text="Grid edge step (px)" FontWeight="Bold" />
                        <TextBox Text="{Binding GridEdgeStep}" Margin="0,2,0,10" />

                        <TextBlock Text="Grid center step (px)" FontWeight="Bold" />
                        <TextBox Text="{Binding GridCenterStep}" Margin="0,2,0,10" />

                        <TextBlock Text="Grid inset (px)" FontWeight="Bold" />
                        <TextBox Text="{Binding GridInset}" Margin="0,2,0,10" />

                        <TextBlock Text="Edge band (%)" FontWeight="Bold" />
                        <TextBox Text="{Binding GridEdgeBandPercent}" Margin="0,2,0,10" />

                        <TextBlock Text="Max enumeration depth (0 = unlimited)" FontWeight="Bold" />
                        <TextBox Text="{Binding MaxEnumerationDepth}" Margin="0,2,0,10" />

                        <TextBlock Text="Dense regions" FontWeight="Bold" />
                        <TextBox Text="{Binding GridDenseRegions}" Margin="0,2,0,10" />

                        <TextBlock Text="Grid layouts (cycle with ; while overlay is up; Grid only)" FontWeight="Bold" />
                        <TextBox Text="{Binding GridLayouts}" AcceptsReturn="True" TextWrapping="Wrap" Height="60" VerticalScrollBarVisibility="Auto" Margin="0,2,0,4" />
                        <TextBlock Text="Layouts separated by ||, fields by |: edgeStep|centerStep|inset|edgeBandPercent|denseRegions. Blank uses the five knobs above." FontStyle="Italic" Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap" />

                        <TextBlock Text="Click-mode order" FontWeight="Bold" />
                        <TextBox Text="{Binding ClickModeOrder}" Margin="0,2,0,10" />

                        <CheckBox Content="Log overlay timings to %TEMP%\hap-timing.log" IsChecked="{Binding TimingLogEnabled}" Margin="0,4,0,10" />

                        <TextBlock Text="Changes apply on the next trigger (hot-reload)." FontStyle="Italic" Foreground="Gray" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem.Content>
        </TabItem>
        <TabItem Header="Keyboard">
            <TabItem.Content>
                <StackPanel Margin="10">
                    <TextBlock Text="Arrow key behavior" FontWeight="Bold" />
                    <ComboBox SelectedValue="{Binding ArrowKeyBehavior}" SelectedValuePath="Content" Margin="0,2,0,4">
                        <ComboBoxItem>Passthrough</ComboBoxItem>
                        <ComboBoxItem>Pan</ComboBoxItem>
                    </ComboBox>
                    <TextBlock Text="Passthrough: arrows move focus in the app beneath. Pan: arrows pan the labels (legacy). Either way Shift+hjkl = large pan, Ctrl+Shift+hjkl = small pan." FontStyle="Italic" Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap" />

                    <TextBlock Text="Small pan step (Ctrl+Shift+hjkl, px)" FontWeight="Bold" />
                    <TextBox Text="{Binding NudgeStep}" Margin="0,2,0,10" />

                    <TextBlock Text="Large pan step (Shift+hjkl, px)" FontWeight="Bold" />
                    <TextBox Text="{Binding NudgeStepFast}" Margin="0,2,0,10" />

                    <TextBlock Text="Hotkey key (System.Windows.Forms.Keys name)" FontWeight="Bold" />
                    <TextBox Text="{Binding HotkeyKey}" Margin="0,2,0,10" />

                    <TextBlock Text="Hotkey modifier (comma-separated: Alt, Control, Shift, Windows)" FontWeight="Bold" />
                    <TextBox Text="{Binding HotkeyModifier}" Margin="0,2,0,10" />

                    <TextBlock Text="One-shot hotkey key (opens a one-shot overlay; System.Windows.Forms.Keys name, e.g. Oemcomma)" FontWeight="Bold" />
                    <TextBox Text="{Binding OneShotHotkeyKey}" Margin="0,2,0,10" />

                    <TextBlock Text="One-shot hotkey modifier (comma-separated: Alt, Control, Shift, Windows)" FontWeight="Bold" />
                    <TextBox Text="{Binding OneShotHotkeyModifier}" Margin="0,2,0,10" />

                    <TextBlock Text="Hotkey changes need a hap.exe restart; everything else hot-reloads." FontStyle="Italic" Foreground="Gray" />
                </StackPanel>
            </TabItem.Content>
        </TabItem>
        <TabItem Header="FontSize">
            <TabItem.Content>
                <StackPanel>
                    <Label Content="Font Size" />
                    <ComboBox SelectedValue="{Binding FontSize}" SelectedValuePath="Content">
                        <ComboBoxItem>8</ComboBoxItem>
                        <ComboBoxItem>9</ComboBoxItem>
                        <ComboBoxItem>10</ComboBoxItem>
                        <ComboBoxItem>11</ComboBoxItem>
                        <ComboBoxItem>12</ComboBoxItem>
                        <ComboBoxItem>13</ComboBoxItem>
                        <ComboBoxItem>14</ComboBoxItem>
                        <ComboBoxItem>15</ComboBoxItem>
                        <ComboBoxItem>16</ComboBoxItem>
                        <ComboBoxItem>17</ComboBoxItem>
                        <ComboBoxItem>18</ComboBoxItem>
                        <ComboBoxItem>19</ComboBoxItem>
                        <ComboBoxItem>20</ComboBoxItem>
                        <ComboBoxItem>21</ComboBoxItem>
                        <ComboBoxItem>22</ComboBoxItem>
                        <ComboBoxItem>23</ComboBoxItem>
                        <ComboBoxItem>24</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </TabItem.Content>
        </TabItem>
    </TabControl>
</Window>
