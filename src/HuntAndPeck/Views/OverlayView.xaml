<local:ForegroundWindow
    x:Class="HuntAndPeck.Views.OverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:HuntAndPeck.Views"
    WindowStyle="None"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    AllowsTransparency="True"
    Topmost="True"
    ShowActivated="False"
    Loaded="OverlayView_OnLoaded">
    <local:ForegroundWindow.Background>
        <SolidColorBrush Color="Transparent" />
    </local:ForegroundWindow.Background>
    <Grid x:Name="layoutGrid">
        <local:HintCanvas Width="{Binding Bounds.Width}" Height="{Binding Bounds.Height}"
                          HintsSource="{Binding Hints}" Opacity="{Binding LabelOpacity}"
                          PillOpacity="{Binding PillOpacity}">
            <local:HintCanvas.RenderTransform>
                <TranslateTransform X="{Binding OffsetX}" Y="{Binding OffsetY}" />
            </local:HintCanvas.RenderTransform>
        </local:HintCanvas>
        <!-- Display-only: shows the typed prefix. Input arrives via the global
             keyboard hook (not a focused TextBox), so the overlay can stay
             non-activated and not dismiss an open context menu. -->
        <TextBox Text="{Binding MatchString, Mode=OneWay}" Width="50"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="4"
                 Background="Transparent" Foreground="White" IsReadOnly="True" Focusable="False" />
        <!-- Bottom-center status strip (sits over the empty middle of the taskbar).
             The click-mode badge hides while suspended so only SUSPENDED shows.
             Semi-transparent so it never fully obscures content behind it. -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                    VerticalAlignment="Bottom" Margin="0,0,0,8" Opacity="0.75">
            <TextBlock Text="{Binding CurrentModeName}"
                       Background="{Binding CurrentModeBrush}"
                       FontFamily="Helvetica, Arial" FontWeight="Bold" FontSize="14"
                       Foreground="Black" Padding="6,2"
                       Visibility="{Binding ClickModeBadgeVisibility}" />
            <TextBlock Text="{Binding TriggerModeLabel}"
                       FontFamily="Helvetica, Arial" FontWeight="Bold" FontSize="12"
                       Foreground="White" Background="DarkSlateBlue" Padding="6,2"
                       Margin="6,0,0,0" />
            <!-- Current grid layout preset when layout cycling is active (Grid + GridLayouts);
                 Collapsed otherwise so no empty box shows. -->
            <TextBlock Text="{Binding LayoutLabel}"
                       FontFamily="Helvetica, Arial" FontWeight="Bold" FontSize="12"
                       Foreground="White" Background="DarkSlateGray" Padding="6,2"
                       Margin="6,0,0,0" Visibility="{Binding LayoutBadgeVisibility}" />
        </StackPanel>
    </Grid>
</local:ForegroundWindow>
