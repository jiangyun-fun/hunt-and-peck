<local:ForegroundWindow
    x:Class="HuntAndPeck.Views.OverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:HuntAndPeck.Views"
    WindowStyle="None"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    AllowsTransparency="True"
    Topmost="True"
    FocusManager.FocusedElement="{Binding ElementName=MatchStringControl}"
    Loaded="OverlayView_OnLoaded"
    PreviewKeyDown="OverlayView_OnPreviewKeyDown">
    <local:ForegroundWindow.Background>
        <SolidColorBrush Color="Transparent" />
    </local:ForegroundWindow.Background>
    <Grid x:Name="layoutGrid">
        <local:HintCanvas Width="{Binding Bounds.Width}" Height="{Binding Bounds.Height}"
                          HintsSource="{Binding Hints}">
            <local:HintCanvas.RenderTransform>
                <TranslateTransform X="{Binding OffsetX}" Y="{Binding OffsetY}" />
            </local:HintCanvas.RenderTransform>
        </local:HintCanvas>
        <TextBlock Text="{Binding ActiveLegend}"
                   FontFamily="Helvetica, Arial" FontWeight="Bold" FontSize="12"
                   Foreground="Black" Background="Yellow"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4"
                   Visibility="Visible" />
        <TextBlock Text="{Binding CurrentModeName}"
                   Background="{Binding CurrentModeBrush}"
                   FontFamily="Helvetica, Arial" FontWeight="Bold" FontSize="14"
                   Foreground="Black"
                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4"
                   Visibility="Visible" />
        <TextBox x:Name="MatchStringControl" Text="{Binding MatchString, UpdateSourceTrigger=PropertyChanged, Mode=OneWayToSource}" Width="50" VerticalAlignment="Bottom" Background="Transparent" Foreground="White" />
        </Grid>
</local:ForegroundWindow>

