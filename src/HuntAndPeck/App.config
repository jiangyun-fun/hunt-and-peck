<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <appSettings>
        <!-- Max UI Automation tree depth to walk when enumerating hints
             (HintSource=Automation only).
             0 = unbounded (walk the whole window).
             Set to e.g. 5 to walk only the top N levels, which is faster on
             large trees (Chromium apps) at the cost of missing deeply-nested
             controls. Hot-reload: edit, save, press Alt+; . -->
        <add key="MaxEnumerationDepth" value="0" />

        <!-- What happens when you complete a hint (type its full label).
             "RealClick" (default) moves the cursor onto the target and fires a
             real left click there. A real click works on Chromium and Electron
             apps (e.g. Feishu) where the UI Automation Invoke pattern does not
             fire. "Invoke" calls the UI Automation Invoke pattern instead. Press
             Space before typing a label to enter move-only mode: jump by label
             and nudge with arrows, then click manually. Hot-reload: edit, save,
             press Alt+; . -->
        <add key="ClickMode" value="RealClick" />

        <!-- Where hints come from.
             "Automation" enumerates the target window's real controls (slow on
             large trees, but precise).
             "Grid" generates an instant grid of cursor-jump points covering the
             window (no enumeration). Type a label to move the cursor there, then
             nudge to click. Works on any app, including Chromium. -->
        <add key="HintSource" value="Grid" />

        <!-- Grid inset: pixels of margin between the grid and each window edge, so
             labels avoid the title bar / screen edge. Hot-reload. -->
        <add key="GridInset" value="10" />

        <!-- Dense regions (HintSource=Grid only): comma-separated regions that get a
             dense cluster of cursor-jump points. Options: Left, Top, Right, Bottom
             (full edge strips), TL, TR, BL, BR (corner squares), Center (sparse
             interior). Default: dense left + top edges and right corners, sparse center
             (sidebar left, tabs top, controls in right corners). Use just "Center" for a
             uniform sparse grid. Hot-reload. -->
        <add key="GridDenseRegions" value="Left,Top,TR,BR,Center" />

        <!-- Edge band: thickness (% of window per edge) of the dense strips/corners. -->
        <add key="GridEdgeBandPercent" value="15" />

        <!-- Point spacing (px): GridEdgeStep in dense regions, GridCenterStep in the
             sparse center. Smaller = more points / finer jumps. Hot-reload. -->
        <add key="GridEdgeStep" value="60" />
        <add key="GridCenterStep" value="160" />

        <!-- Characters used to build hint labels. More characters means more short
             labels: 14 gives ~196 two-char labels, 26 (A-Z) gives ~676. For dense
             grids (26x26), use 26 so every label stays two chars. Hot-reload. -->
        <add key="HintCharacters" value="ABCDEFGHIJKLMNOPQRSTUVWXYZ" />

        <!-- Arrow-key nudge step (px) in move-only mode: NudgeStep for plain
             arrows, NudgeStepFast for Shift plus arrows. Hot-reload. -->
        <add key="NudgeStep" value="3" />
        <add key="NudgeStepFast" value="15" />
    </appSettings>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5.1" />
    </startup>
</configuration>
