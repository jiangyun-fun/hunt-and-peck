<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <appSettings>
        <!-- Max UI Automation tree depth to walk when enumerating hints.
             0 = unbounded (walk the whole window; original behavior).
             Set to e.g. 5 to walk only the top N levels, which is faster on
             large trees (Chromium apps) at the cost of missing deeply-nested
             controls. Changes apply on the next hotkey press (hot-reload, no
             restart needed): edit this value, save, then press Alt+; . -->
        <add key="MaxEnumerationDepth" value="0" />

        <!-- What happens when you type a unique hint's letters.
             "Click" (default) invokes the target; "MoveMouse" moves the cursor
             onto the target without clicking (useful when Invoke doesn't fire).
             Hot-reload: edit, save, press Alt+; . -->
        <add key="HintAction" value="Click" />

        <!-- Where hints come from.
             "Automation" (default) enumerates the target window's real controls.
             "Grid" generates an instant grid of cursor-jump points covering the
             window (no enumeration). Type a label to move the cursor there, then
             nudge to click. Useful for apps where enumeration is slow/unreliable. -->
        <add key="HintSource" value="Automation" />

        <!-- Grid density (HintSource=Grid only). More points = finer jumps but more
             labels/visual clutter. Defaults: 12 x 8 (96 points). -->
        <add key="GridCols" value="12" />
        <add key="GridRows" value="8" />
    </appSettings>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5.1" />
    </startup>
</configuration>